# =============================================================================
# Ollama
# =============================================================================
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=gemma3:latest

# =============================================================================
# Workspace
# =============================================================================
# Directorio raíz del agente (por defecto: directorio actual al iniciar)
# WORKSPACE_ROOT=/home/usuario/mi-proyecto

# =============================================================================
# Persistencia
# =============================================================================
# Base de datos SQLite para sesiones y conversaciones
# CHAT_DB_PATH=~/.local/share/ollama-chat-gui/sessions.db

# =============================================================================
# RAG Semántico
# =============================================================================
# Desactivar para usar solo el RAG por keywords (bag-of-words)
EMBEDDING_ENABLED=true

# Modelo de embeddings en Ollama (ejecutar: ollama pull nomic-embed-text)
EMBEDDING_MODEL=nomic-embed-text

# Directorio donde ChromaDB persiste el índice vectorial
# CHROMA_DB_PATH=~/.local/share/ollama-chat-gui/chroma

# Score mínimo de similitud cosine (0-1) para emitir sugerencias proactivas
# Valores más altos = menos sugerencias pero más precisas
RAG_PROACTIVE_SCORE_THRESHOLD=0.75

# Turnos de cooldown entre dos rondas de sugerencias para el mismo set de archivos
RAG_PROACTIVE_COOLDOWN_TURNS=2

# Número de chunks semánticos a recuperar por query
RAG_SEMANTIC_TOP_K=6

# =============================================================================
# Memoria a Largo Plazo
# =============================================================================
# Habilitar sistema de memoria persistente (workspace + perfil global)
MEMORY_ENABLED=true

# Extraer memorias automáticamente de cada conversación (1 llamada LLM extra)
MEMORY_AUTO_EXTRACT=true

# Máximo de memorias por workspace
# MEMORY_MAX_WORKSPACE_ITEMS=50

# Máximo de rasgos en el perfil global del usuario
# MEMORY_MAX_PROFILE_ITEMS=30

# =============================================================================
# Reflexión Crítica y Auto-corrección
# =============================================================================
# Habilitar revisión automática de respuestas antes de entregarlas (1 llamada LLM extra)
REFLECTION_ENABLED=true

# Temperatura para la reflexión (baja = más consistente)
REFLECTION_TEMPERATURE=0.3

# Número máximo de reintentos cuando un paso de plan falla
MAX_STEP_RETRIES=3
